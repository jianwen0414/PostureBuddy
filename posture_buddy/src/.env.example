# Copy this file to .env (in this same src/ directory) and fill in your key.
#   cp .env.example .env
#
# IMPORTANT: feedback_controller_node.py resolves this file RELATIVE TO ITSELF
# (dirname(__file__)/.env), NOT the directory you run roslaunch from. It must
# live next to the node scripts in posture_buddy/src/ — not the repo root.
#
# .env is gitignored — never commit your real key.

# OpenRouter API key — used by Module 4 (feedback_controller_node) to reach
# the DeepSeek V4 Flash model (deepseek/deepseek-v4-flash) for the two-way
# conversation. Get one at https://openrouter.ai/keys
# Without this, the node still runs but falls back to canned TTS lines and
# logs "DeepSeek disabled".
OPENROUTER_API_KEY=sk-or-your-key-here

<launch>

  <!-- USB webcam driver ─────────────────────────────────────────────────────
       Adjust video_device if the camera is not /dev/video0 on the robot.
       usb_cam package: sudo apt install ros-noetic-usb-cam
  -->
  <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device" value="/dev/video2"/>
    <param name="image_width" value="640"/>
    <param name="image_height" value="480"/>
    <param name="pixel_format" value="yuyv"/>
    <param name="framerate" value="10"/>
    <param name="io_method" value="mmap"/>
    <param name="camera_frame_id" value="usb_cam" />
  </node>

  <!-- Module 1: Vision & Kinematics ─────────────────────────────────────────
       required="true" shuts the entire launch down if this node crashes,
       since all downstream modules depend on /user_kinematics.
  -->
  <node pkg="posture_buddy"
        type="pose_estimation_node.py"
        name="pose_estimation_node"
        output="screen"
        required="true" />

</launch>

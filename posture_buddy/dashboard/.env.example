# Copy this file to .env.local and fill in values for your machine.
# .env.local is gitignored — never commit it.

# WebSocket URL for the rosbridge server running on the robot.
# Change <robot-ip> to the actual IP address of your Juno robot.
# Default port for rosbridge_suite is 9090.
NEXT_PUBLIC_WS_URL=ws://<robot-ip>:9090

# Set to "true" to use the built-in mock WebSocket instead of connecting to the robot.
# Useful for local UI development without the robot running.
# Set to "false" (or remove the line) when connecting to the real robot.
NEXT_PUBLIC_MOCK_WS=true

# ROS topic name for the compressed camera image stream.
# Must match the topic published by the camera node (Module 1).
# Confirm the exact topic name with the team member owning Module 1.
NEXT_PUBLIC_CAMERA_TOPIC=/camera/image_raw/compressed
